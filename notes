const prompt = "a samurai in tokyo";
const url = `https://image.pollinations.ai/prompt/${encodeURIComponent(prompt)}`;


Preset:
"High quality illustration, cinematic lighting, ultra detailed"

User:
"a samurai in modern Tokyo"

Final:
"High quality illustration, cinematic lighting, ultra detailed, a samurai in modern Tokyo"


